GROQ_API_KEY=your_groq_api_key_here

# Optional: override the Groq model (default: llama-3.3-70b-versatile).
# A lighter model like llama-3.1-8b-instant has a larger free-tier daily budget.
# GROQ_MODEL=llama-3.1-8b-instant

# Auth.js (NextAuth v5) — required for login
# Generate a secret with: openssl rand -base64 33
AUTH_SECRET=your_auth_secret_here

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# Supabase — for persistent shareable portfolio URLs (/p/<slug>). Server-side only.
# Create a project at supabase.com, then copy these from Settings → API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
